rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: solo lectura/escritura por el propio usuario
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Negocios: lectura pública, escritura solo para usuarios autenticados
    match /negocios/{negocioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
match /logos/{userId}/{allPaths=**} {
  allow read: if true;
  allow write: if request.auth != null && request.auth.uid == userId;
}
    // Giros: lectura para el propio usuario o el dueño del negocio,
    // creación solo para usuarios autenticados y con datos válidos
    match /giros/{giroId} {
      allow read: if request.auth != null && 
                   (resource.data.usuarioId == request.auth.uid ||
                    exists(/databases/$(database)/documents/negocios/$(resource.data.negocioId)) &&
                    get(/databases/$(database)/documents/negocios/$(resource.data.negocioId)).data.creadoPor == request.auth.uid);
      allow create: if request.auth != null && 
                     request.resource.data.usuarioId == request.auth.uid &&
                     request.resource.data.premioObtenido is string &&
                     request.resource.data.indicePremio is number;
      allow update, delete: if false;
    }
  }
}